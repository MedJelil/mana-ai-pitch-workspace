# Database (Postgres / Neon, etc.)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# App URL (used for auth callbacks and email links)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Mana AI <noreply@yourdomain.com>

# Pitch generation – PITCH_PROVIDER: "gemini" (default) or "claude"
PITCH_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Seed (optional – default: seed@mana.local)
# SEED_USER_EMAIL=seed@mana.local
